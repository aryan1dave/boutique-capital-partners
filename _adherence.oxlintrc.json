{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/navigation/**",
              "documentcentre-sections.jsx",
              "insights-sections.jsx",
              "puffin-sections.jsx",
              "redesign-sections.jsx",
              "riverroad-sections.jsx",
              "site-polish.js",
              "team-sections.jsx",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Montserrat|Roboto|Roboto Slab))/i]",
        "message": "Font not provided by the design system. Available: Montserrat, Roboto, Roboto Slab."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|arrow|href|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, arrow, href, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline|cream|tertiary|text)$/]",
        "message": "<Button> variant must be one of 'primary' | 'outline' | 'cream' | 'tertiary' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalloutBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<CalloutBox> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|children|style|key|ref|className|style|children)$/]",
        "message": "<ContactCard> doesn't accept that prop. Declared props: icon, label, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactCard'] > JSXAttribute[name.name='icon'] > Literal[value!=/^(?:phone|email|location)$/]",
        "message": "<ContactCard> icon must be one of 'phone' | 'email' | 'location'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureList'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|title|onDark|style|key|ref|className|style|children)$/]",
        "message": "<FeatureList> doesn't accept that prop. Declared props: items, title, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|links|style|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: logoSrc, links, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='InsightCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|date|category|title|excerpt|cta|href|style|key|ref|className|style|children)$/]",
        "message": "<InsightCard> doesn't accept that prop. Declared props: image, date, category, title, excerpt, cta, href, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|items|sticky|style|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: logoSrc, items, sticky, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|lead|onDark|size|align|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: title, lead, onDark, size, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg|xl)$/]",
        "message": "<SectionHeading> size must be one of 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<SectionHeading> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|color|children|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant, color, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:pill|eyebrow)$/]",
        "message": "<Tag> variant must be one of 'pill' | 'eyebrow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:navy|coral|muted)$/]",
        "message": "<Tag> color must be one of 'navy' | 'coral' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeamCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|name|linkLabel|onClick|size|style|key|ref|className|style|children)$/]",
        "message": "<TeamCard> doesn't accept that prop. Declared props: image, name, linkLabel, onClick, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeamCard'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<TeamCard> size must be one of 'md' | 'lg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
